        {
          "listen": "test",
          "script": {
            "exec": [
              "// Tests do LOGIN\r",
              "pm.test(\"Login 200 OK\", () => pm.response.to.have.status(200));\r",
              "\r",
              "let loginResp = {};\r",
              "try { loginResp = pm.response.json(); } catch (e) {}\r",
              "\r",
              "pm.expect(loginResp).to.have.property(\"accessToken\");\r",
              "pm.expect(loginResp).to.have.property(\"refreshToken\");\r",
              "\r",
              "const oldAccess  = pm.environment.get(\"accessToken\");\r",
              "const oldRefresh = pm.environment.get(\"refreshToken\");\r",
              "if (oldAccess)  pm.environment.set(\"prevAccessToken\", oldAccess);\r",
              "if (oldRefresh) pm.environment.set(\"prevRefreshToken\", oldRefresh);\r",
              "\r",
              "pm.environment.set(\"accessToken\", loginResp.accessToken || \"\");\r",
              "pm.environment.set(\"refreshToken\", loginResp.refreshToken || \"\");\r",
              "pm.environment.set(\"tokenCreatedAt\", Date.now());\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
