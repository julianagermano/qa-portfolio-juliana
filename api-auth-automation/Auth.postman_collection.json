  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// Auto-recuperação: se 401, tenta refresh; se falhar, faz login; reenvia a mesma requisição 1x.\r",
          "\r",
          "if (pm.response.code === 200) {\r",
          "  pm.variables.unset(\"retriedAfterRefresh\");\r",
          "  return;\r",
          "}\r",
          "\r",
          "if (pm.response.code === 401 && pm.variables.get(\"retriedAfterRefresh\") !== \"true\") {\r",
          "  pm.variables.set(\"retriedAfterRefresh\", \"true\");\r",
          "\r",
          "  const baseUrl  = pm.environment.get(\"baseUrl\");\r",
          "  const rToken   = pm.environment.get(\"refreshToken\");\r",
          "  const username = pm.environment.get(\"username\");\r",
          "  const password = pm.environment.get(\"password\");\r",
          "\r",
          "  function saveTokens(data) {\r",
          "    const oldAccess  = pm.environment.get(\"accessToken\");\r",
          "    const oldRefresh = pm.environment.get(\"refreshToken\");\r",
          "    if (oldAccess)  pm.environment.set(\"prevAccessToken\", oldAccess);\r",
          "    if (oldRefresh) pm.environment.set(\"prevRefreshToken\", oldRefresh);\r",
          "\r",
          "    pm.environment.set(\"accessToken\", data.accessToken);\r",
          "    pm.environment.set(\"refreshToken\", data.refreshToken);\r",
          "    pm.environment.set(\"tokenCreatedAt\", Date.now());\r",
          "  }\r",
          "\r",
          "  function cloneCurrentRequestWith(newAccessToken) {\r",
          "    const req = {\r",
          "      url: pm.request.url.toString(),\r",
          "      method: pm.request.method,\r",
          "      header: pm.request.headers.map(h => ({ key: h.key, value: h.value })),\r",
          "      body: undefined\r",
          "    };\r",
          "    if (pm.request.body) {\r",
          "      const mode = pm.request.body.mode;\r",
          "      const b = { mode };\r",
          "      if (mode === \"raw\")        b.raw = pm.request.body.raw;\r",
          "      if (mode === \"urlencoded\") b.urlencoded = pm.request.body.urlencoded;\r",
          "      if (mode === \"formdata\")   b.formdata = pm.request.body.formdata;\r",
          "      if (mode === \"graphql\")    b.graphql = pm.request.body.graphql;\r",
          "      req.body = b;\r",
          "    }\r",
          "    req.header = req.header.filter(h => h.key.toLowerCase() !== \"authorization\");\r",
          "    req.header.push({ key: \"Authorization\", value: `Bearer ${newAccessToken}` });\r",
          "    return req;\r",
          "  }\r",
          "\r",
          "  function doLoginFallback() {\r",
          "    pm.sendRequest({\r",
          "      url: `${baseUrl}/auth/login`,\r",
          "      method: \"POST\",\r",
          "      header: { \"Content-Type\": \"application/json\" },\r",
          "      body: { mode: \"raw\", raw: JSON.stringify({ username, password }) }\r",
          "    }, (err, res) => {\r",
          "      if (!err && res.code === 200) {\r",
          "        const d = res.json();\r",
          "        saveTokens(d);\r",
          "        pm.sendRequest(cloneCurrentRequestWith(d.accessToken), (e2, r2) => {\r",
          "          pm.variables.unset(\"retriedAfterRefresh\");\r",
          "          pm.test(\"Reenvio após login → 200\", () => pm.expect(r2.code).to.eql(200));\r",
          "        });\r",
          "      } else {\r",
          "        pm.variables.unset(\"retriedAfterRefresh\");\r",
          "        pm.test(\"Falha ao recuperar token (refresh e login)\", () => {\r",
          "          pm.expect.fail(`Recovery falhou: ${err ? err.message : res.code}`);\r",
          "        });\r",
          "      }\r",
          "    });\r",
          "  }\r",
          "\r",
          "  // 1) tenta refresh primeiro\r",
          "  if (rToken) {\r",
          "    pm.sendRequest({\r",
          "      url: `${baseUrl}/auth/refresh`,\r",
          "      method: \"POST\",\r",
          "      header: { \"Content-Type\": \"application/json\" },\r",
          "      body: { mode: \"raw\", raw: JSON.stringify({ refreshToken: rToken }) }\r",
          "    }, (err, res) => {\r",
          "      if (!err && res.code === 200) {\r",
          "        const d = res.json();\r",
          "        saveTokens(d);\r",
          "        pm.sendRequest(cloneCurrentRequestWith(d.accessToken), (e2, r2) => {\r",
          "          pm.variables.unset(\"retriedAfterRefresh\");\r",
          "          pm.test(\"Reenvio após refresh → 200\", () => pm.expect(r2.code).to.eql(200));\r",
          "        });\r",
          "      } else {\r",
          "        // 2) se refresh falhar → login\r",
          "        doLoginFallback();\r",
          "      }\r",
          "    });\r",
          "  } else {\r",
          "    // sem refreshToken salvo → login direto\r",
          "    doLoginFallback();\r",
          "  }\r",
          "} else {\r",
          "  pm.variables.unset(\"retriedAfterRefresh\");\r",
          "}"
        ]
      }
    }
  ]
}