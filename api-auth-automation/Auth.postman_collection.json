    {
      "name": "Me",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const status = pm.response.code;\r",
              "let body = {};\r",
              "try { body = pm.response.json(); } catch(e){}\r",
              "\r",
              "pm.test(`Status recebido: ${status}`, () => {\r",
              "  pm.expect([200, 401, 403, 500]).to.include(status);\r",
              "});\r",
              "\r",
              "if (status === 200) {\r",
              "  pm.test(\"200 OK - resposta JSON válida\", () => {\r",
              "    pm.response.to.be.json;\r",
              "    pm.expect(body).to.have.property(\"id\");\r",
              "    pm.expect(body).to.have.property(\"username\");\r",
              "    pm.expect(body).to.have.property(\"email\");\r",
              "  });\r",
              "\r",
              "  pm.test(\"Tipos corretos\", () => {\r",
              "    pm.expect(body.id).to.be.a(\"number\");\r",
              "    pm.expect(body.username).to.be.a(\"string\");\r",
              "    pm.expect(body.email).to.be.a(\"string\");\r",
              "  });\r",
              "}\r",
              "\r",
              "if (status === 401) {\r",
              "  pm.test(\"401 - não autenticado\", () => {\r",
              "    pm.expect(body).to.have.property(\"message\");\r",
              "  });\r",
              "}\r",
              "\r",
              "if (status === 403) {\r",
              "  pm.test(\"403 - sem permissão / refresh inválido\", () => {\r",
              "    pm.expect(body).to.have.property(\"message\");\r",
              "  });\r",
              "}\r",
              "\r",
              "if (status === 500) {\r",
              "  // DummyJSON às vezes retorna 500 \"invalid signature\" para token inválido\r",
              "  pm.test(\"500 - comportamento da API de teste\", () => {\r",
              "    pm.expect(body).to.have.property(\"message\");\r",
              "  });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
